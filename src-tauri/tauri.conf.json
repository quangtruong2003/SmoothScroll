{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "SmoothScroll",
  "version": "1.19.3",
  "identifier": "com.smoothscroll.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "SmoothScroll",
        "width": 800,
        "height": 600,
        "minWidth": 480,
        "minHeight": 400,
        "resizable": true,
        "fullscreen": false,
        "center": true,
        "visible": false,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true
      },
      {
        "label": "tray-panel",
        "title": "",
        "width": 220,
        "height": 600,
        "resizable": false,
        "decorations": false,
        "transparent": true,
        "skipTaskbar": true,
        "alwaysOnTop": true,
        "visible": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data: asset: https://asset.localhost https://img.vietqr.io"
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": [
      "nsis",
      "msi",
      "app",
      "dmg",
      "deb",
      "appimage"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "category": "Utility",
    "shortDescription": "Cross-platform smooth scrolling",
    "longDescription": "Brings macOS-style smooth scrolling to Windows and macOS.",
    "copyright": "Copyright 2026 SmoothScroll contributors",
    "windows": {
      "wix": {
        "language": [
          "en-US",
          "vi-VN",
          "zh-CN"
        ]
      },
      "nsis": {
        "displayLanguageSelector": true,
        "installerIcon": "icons/icon.ico",
        "installMode": "currentUser",
        "languages": [
          "English",
          "Vietnamese",
          "SimpChinese"
        ]
      },
      "certificateThumbprint": null,
      "digestAlgorithm": "sha256"
    },
    "linux": {
      "deb": {
        "depends": [
          "libwebkit2gtk-4.1-0",
          "libayatana-appindicator3-1",
          "libx11-6",
          "libxi6",
          "libxtst6"
        ]
      },
      "appimage": {
        "bundleMediaFramework": true
      }
    },
    "macOS": {
      "frameworks": [],
      "minimumSystemVersion": "12.0",
      "entitlements": null,
      "exceptionDomain": null,
      "signingIdentity": null,
      "infoPlist": "Info.plist",
      "providerShortName": null,
      "dmg": {
        "background": null,
        "windowSize": {
          "width": 540,
          "height": 380
        }
      }
    }
  },
  "plugins": {
    "updater": {
      "active": true,
      "endpoints": [
        "https://github.com/quangtruong2003/SmoothScroll/releases/latest/download/latest.json"
      ],
      "dialog": false,
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEM0RjRGM0E0NjRCNUYwOUIKUldTYjhMVmtwUFAweExRd0I3NjF4emNtdlFIVit1akw4djd0S1JLamY0NjVwQjZuTDR4UTFOR3EK"
    }
  }
}
