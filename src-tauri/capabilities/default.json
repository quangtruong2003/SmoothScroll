{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Default capability for the main window",
  "windows": ["main", "tray-panel"],
  "permissions": [
    "core:default",
    "updater:default",
    "process:default",
    {
      "identifier": "shell:allow-open",
      "allow": [
        { "url": "https://github.com/*" },
        { "url": "https://*.github.io/*" },
        { "url": "https://*.github.com/*" }
      ]
    }
  ]
}
